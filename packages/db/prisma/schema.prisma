generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  passwordHash String
  name         String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  projects     Project[]
  documents    Document[]
  jobs         CheckJob[]
  chunks       EmbeddingChunk[]
  toolCalls    MCPToolCall[]
}

model Project {
  id                  String     @id @default(cuid())
  userId              String
  name                String
  description         String?
  techStack           String?
  projectPath         String
  defaultStartCommand String
  defaultUrl          String
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  user                User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents           Document[]
  chunks              EmbeddingChunk[]
  jobs                CheckJob[]
}

model Document {
  id        String   @id @default(cuid())
  userId    String
  projectId String
  title     String
  type      String
  content   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  chunks    EmbeddingChunk[]
}

model EmbeddingChunk {
  id         String   @id @default(cuid())
  userId     String
  projectId  String
  documentId String?
  content    String
  metadata   Json?
  embedding  Json?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  document   Document? @relation(fields: [documentId], references: [id], onDelete: SetNull)
}

model CheckJob {
  id          String     @id @default(cuid())
  userId      String
  projectId   String
  status      String
  targetUrl   String
  startCommand String
  requirement String
  options     Json?
  startedAt   DateTime?
  finishedAt  DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  plan        AcceptancePlan?
  checkItems  CheckItem[]
  results     CheckResult[]
  evidence    Evidence[]
  report      Report?
  logs        AgentLog[]
}

model AcceptancePlan {
  id         String      @id @default(cuid())
  jobId      String      @unique
  rawPlan    Json
  status     String
  approvedAt DateTime?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  job        CheckJob    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  checkItems CheckItem[]
}

model CheckItem {
  id          String      @id @default(cuid())
  jobId       String
  planId      String
  checkKey    String
  title       String
  description String
  type        String
  priority    String
  steps       Json
  expected    String
  createdAt   DateTime    @default(now())
  job         CheckJob    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  plan        AcceptancePlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  results     CheckResult[]
}

model CheckResult {
  id          String    @id @default(cuid())
  jobId       String
  checkItemId String
  status      String
  reason      String
  actual      Json?
  durationMs  Int
  createdAt   DateTime  @default(now())
  job         CheckJob  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  checkItem   CheckItem @relation(fields: [checkItemId], references: [id], onDelete: Cascade)
  evidence    Evidence[]
}

model Evidence {
  id            String       @id @default(cuid())
  jobId         String
  checkResultId String?
  type          String
  filePath      String?
  content       String?
  metadata      Json?
  createdAt     DateTime     @default(now())
  job           CheckJob     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  checkResult   CheckResult? @relation(fields: [checkResultId], references: [id], onDelete: SetNull)
}

model Report {
  id        String   @id @default(cuid())
  jobId     String   @unique
  markdown  String
  json      Json
  htmlPath  String?
  createdAt DateTime @default(now())
  job       CheckJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model AgentLog {
  id        String   @id @default(cuid())
  jobId     String
  nodeName  String
  level     String
  eventType String
  message   String
  payload   Json?
  createdAt DateTime @default(now())
  job       CheckJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model MCPToolCall {
  id        String   @id @default(cuid())
  userId    String
  toolName  String
  input     Json
  output    Json?
  status    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
